PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.xxxx.mongodb.net/axt_db?retryWrites=true&w=majority
JWT_SECRET=your_ultra_secure_long_random_string_here
JWT_REFRESH_SECRET=your_ultra_secure_long_refresh_string_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Gmail SMTP credentials used to send real password-reset OTP emails.
# EMAIL_USER must be a full Gmail address, e.g. yourshop@gmail.com
# EMAIL_PASS must be a 16-character Google "App Password" (NOT your normal Gmail login password).
# Generate one at: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM_NAME=AXT Attitude X T-Shirts

# Business details shown on generated PDF invoices — set these to your real
# registered business info; each has a placeholder fallback if left unset.
BUSINESS_NAME=AXT - Attitude X T-Shirts
BUSINESS_ADDRESS=Your full registered business address
BUSINESS_GSTIN=your_15_char_gstin
BUSINESS_EMAIL=support@yourdomain.com
BUSINESS_PHONE=+91XXXXXXXXXX
